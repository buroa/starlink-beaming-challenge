{
  "private": true,
  "scripts": {
    "build:wasm-st": "cross-env RUSTFLAGS= wasm-pack build --target web -- --no-default-features",
    "build:wasm-mt": "wasm-pack build --target web --out-dir pkg-parallel -- --no-default-features --features parallel -Z build-std=panic_abort,std",
    "build:wasm": "run-p build:wasm-st build:wasm-mt",
    "build": "npm run build:wasm && webpack build",
    "serve": "npm run build && serve dist --config serve.json"
  },
  "devDependencies": {
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "10.1.0",
    "html-webpack-plugin": "^5.6.7",
    "npm-run-all": "4.1.5",
    "serve": "^14.2.6",
    "wasm-pack": "0.15.0",
    "webpack": "5.107.2",
    "webpack-cli": "7.0.3"
  },
  "dependencies": {
    "wasm-feature-detect": "1.8.0"
  }
}
